# =============================================================================
# PRODUCTION — Render (backend)
# Copy these to Render → Environment. Do not commit real values.
# =============================================================================
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret
CORS_ORIGINS=https://your-app.vercel.app
ADMIN_EMAILS=admin@yourcompany.com

# Required on Render for KSP scrape (KSP blocks datacenter IPs). Free tier: scraperapi.com
# KSP_SCRAPER_API_KEY=your-scraperapi-key
# Or any HTTP proxy: KSP_HTTPS_PROXY=http://user:pass@host:port

# Optional: also set FRONTEND_URL=https://your-app.vercel.app (merged into CORS)
# FRONTEND_URL=

# =============================================================================
# PRODUCTION — Vercel (frontend)
# Set in Vercel → Project → Settings → Environment Variables
# =============================================================================
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_API_URL=https://resparts-api.onrender.com
