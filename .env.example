# Database (local Docker: docker compose up -d)
DATABASE_URL=postgresql://tradein:tradein@localhost:5433/tradein

# Supabase (hosted or supabase start — for Auth)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Backend
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production: add your Vercel URL, e.g. CORS_ORIGINS=https://your-app.vercel.app
# Or set FRONTEND_URL=https://your-app.vercel.app (appended to CORS list)
# FRONTEND_URL=

# Admin emails (comma-separated) — Supabase Auth user emails with admin role
ADMIN_EMAILS=tomerbardao@tradein.local

# KSP on Render/cloud: set one of these (ScraperAPI free tier works)
# KSP_SCRAPER_API_KEY=
# KSP_HTTPS_PROXY=

# Frontend (copy to frontend/.env.local)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_API_URL=http://localhost:8000
